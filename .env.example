# ============================================================
# Django Core
# ============================================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ============================================================
# Database (PostgreSQL)
# Local Docker default: postgres://admin:admin123@localhost:12322/project
# Docker Compose service default: postgres://admin:admin123@postgres:5432/project
# ============================================================
DATABASE_URL=postgres://admin:admin123@postgres:5432/project

# ============================================================
# Azure OpenAI — Chat (required)
# Primary LLM used by career & Stream & Subject Selection sessions.
# ============================================================
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.2

# ============================================================
# Azure OpenAI — Text-to-Speech (optional)
# Falls back to AZURE_OPENAI_* values when omitted.
# ============================================================
AZURE_OPENAI_TTS_API_KEY=your-azure-tts-api-key
AZURE_OPENAI_TTS_ENDPOINT=https://your-azure-tts-resource.openai.azure.com
AZURE_OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts

# ============================================================
# Azure OpenAI — Realtime Voice API (optional)
# Used by WebSocket consumers for live voice sessions.
# ============================================================
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-1.5
AZURE_OPENAI_REALTIME_API_VERSION=2024-10-01-preview

# ============================================================
# SendGrid — Email (required for OTP registration & password reset)
# ============================================================
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=your-verified-sender-email@example.com

# ============================================================
# Google Gemini (optional — used by RAG / conv_rag module)
# ============================================================
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# Deepgram (optional — alternative speech-to-text provider)
# ============================================================
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# ============================================================
# CORS
# Set CORS_ALLOW_ALL_ORIGINS=False in production and list
# your frontend origins in CORS_ALLOWED_ORIGINS.
# ============================================================
CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================
# Production Settings (uncomment for production deployments)
# ============================================================
# REDIS_URL=redis://localhost:6379
# DB_CONN_MAX_AGE=600
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# ENABLE_HSTS=True
# LOG_FILE_PATH=/var/log/django/error.log
# DJANGO_LOG_LEVEL=INFO
